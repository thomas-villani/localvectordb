# LocalVectorDB Environment Variables
# Copy this file to .env and fill in the values you need.

# =============================================================================
# Server Configuration
# =============================================================================
# LVDB_SERVER_CONFIG=/path/to/config.toml    # Path to TOML/JSON config file
# LVDB_HOST=127.0.0.1                        # Server bind address
# LVDB_PORT=8000                             # Server port
# LVDB_DEBUG=false                           # Enable debug mode
# LVDB_LOG_LEVEL=INFO                        # Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LVDB_DATABASE_ROOT_DIR=./databases         # Directory for database storage
# LVDB_DISABLE_OLLAMA_CHECK=false            # Skip Ollama availability check on startup

# =============================================================================
# Authentication
# =============================================================================
# LVDB_API_KEY=                              # API key for client authentication

# =============================================================================
# Embedding Provider Configuration
# =============================================================================
# LVDB_EMBEDDING_PROVIDER=ollama             # Provider: ollama, openai, google, jina, huggingface
# LVDB_EMBEDDING_MODEL=nomic-embed-text      # Model name

# Provider-specific API keys (set the one matching your provider):
# OPENAI_API_KEY=sk-...                      # OpenAI API key
# OLLAMA_URL=http://localhost:11434           # Ollama server URL
# GEMINI_API_KEY=                            # Google Gemini API key
# GOOGLE_API_KEY=                            # Alternative Google API key
# JINA_API_KEY=                              # Jina AI API key
# HF_TOKEN=                                  # HuggingFace API token
# HUGGINGFACE_TOKEN=                         # Alternative HuggingFace token

# =============================================================================
# MCP Server Configuration
# =============================================================================
# LVDB_MCP_MODE=read-only                   # MCP mode: read-only or read-write
# LVDB_MCP_DATABASES_ROOT=./databases       # Root directory for MCP databases
# LVDB_MCP_DATABASES_MAP=db1=./path1        # Comma-separated name=path mappings
# LVDB_MCP_EMBEDDING_PROVIDER=ollama        # Embedding provider for MCP
# LVDB_MCP_EMBEDDING_MODEL=nomic-embed-text # Embedding model for MCP
# LVDB_MCP_CHUNK_SIZE=500                   # Chunk size for MCP document processing
# LVDB_MCP_LOG_LEVEL=INFO                   # MCP server log level
# LVDB_MCP_CONFIG=/path/to/mcp-config.toml  # Path to MCP config file
